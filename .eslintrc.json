{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": ["google", "eslint:recommended", "plugin:react/recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": ["react"],
  "rules": {
    "require-jsdoc": "off",               // JSDoc 요구 끔 (Google style 기본값은 on)
    "react/prop-types": "off",            // PropTypes 사용 안 해도 경고 안 나게
    "max-len": ["warn", { "code": 120 }], // 한 줄 최대 길이 120자로 완화
    "quotes": ["error", "double"],        // 작은따옴표 대신 큰따옴표 강제
    "semi": ["error", "always"]           // 세미콜론 항상 사용
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  }
}

